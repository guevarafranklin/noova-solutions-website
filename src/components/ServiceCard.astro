---
interface Props {
  title: string;
  description: string;
  cta: { label: string; href: string };
  icon?: "team" | "squad" | "ai";
  highlight?: boolean;
}

const { title, description, cta, icon = "team", highlight = false } = Astro.props;
---

<article class:list={["service-card", highlight && "service-card--highlight"]}>
  <div class="service-icon" aria-hidden="true">
    {icon === "team" && (
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="9" cy="8" r="3.5" />
        <circle cx="17" cy="10" r="2.5" />
        <path d="M3 19c0-3.5 2.7-6 6-6s6 2.5 6 6" />
        <path d="M15 17c.4-2 2-3.5 4-3.5s3.6 1.5 4 3.5" />
      </svg>
    )}
    {icon === "squad" && (
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
        <rect x="3" y="4" width="18" height="16" rx="2.5" />
        <path d="M3 9h18" />
        <path d="M9 14h2" />
        <path d="M9 17h6" />
      </svg>
    )}
    {icon === "ai" && (
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 3v2" />
        <rect x="5" y="6" width="14" height="12" rx="3" />
        <path d="M9 11h.01M15 11h.01" />
        <path d="M9 15c1 1 2 1.5 3 1.5s2-.5 3-1.5" />
        <path d="M3 12h2M19 12h2" />
      </svg>
    )}
  </div>
  <h3>{title}</h3>
  <p>{description}</p>
  <a href={cta.href} class="btn btn-link service-cta">{cta.label}</a>
</article>

<style>
  .service-card {
    display: flex;
    flex-direction: column;
    padding: 28px;
    background-color: var(--color-paper);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-card);
    transition: border-color var(--transition-base), box-shadow var(--transition-base);
    height: 100%;
  }

  .service-card:hover {
    border-color: var(--color-line-strong);
    box-shadow: var(--shadow-card);
  }

  .service-card--highlight {
    background-color: var(--color-shell);
    border-color: transparent;
  }

  .service-icon {
    width: 44px;
    height: 44px;
    border-radius: var(--radius-tile);
    display: grid;
    place-items: center;
    background-color: var(--color-ink);
    color: var(--color-paper);
    margin-bottom: var(--space-6);
  }

  .service-card--highlight .service-icon {
    background-color: var(--color-primary);
  }

  .service-icon svg { width: 22px; height: 22px; }

  .service-card h3 {
    font-size: var(--fs-h4);
    line-height: 1.15;
    letter-spacing: -0.013em;
    color: var(--color-ink);
    margin-bottom: var(--space-3);
  }

  .service-card p {
    font-size: var(--fs-body-lg);
    color: var(--color-muted);
    margin-bottom: var(--space-6);
    line-height: 1.55;
    flex: 1;
  }

  .service-cta {
    align-self: flex-start;
  }
</style>
