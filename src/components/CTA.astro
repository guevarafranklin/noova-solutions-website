---
interface Props {
  headline: string;
  subtext?: string;
  cta: { label: string; href: string };
}

const { headline, subtext, cta } = Astro.props;
---

<section class="cta-banner">
  <div class="container cta-inner">
    <div class="cta-content">
      <h2>{headline}</h2>
      {subtext && <p>{subtext}</p>}
    </div>
    <a href={cta.href} class="btn btn-on-brand btn-lg cta-btn">{cta.label}</a>
  </div>
</section>

<style>
  .cta-banner {
    position: relative;
    overflow: hidden;
    padding-block: var(--space-20);
    background-color: var(--color-primary);
    color: var(--color-on-brand);
  }

  .cta-inner {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-10);
    flex-wrap: wrap;
  }

  .cta-content { max-width: 640px; }

  .cta-banner h2 {
    color: var(--color-on-brand);
    margin-bottom: var(--space-3);
  }

  .cta-banner p {
    color: var(--color-on-brand-muted);
    font-size: var(--fs-body-lg);
    margin: 0;
    line-height: 1.55;
  }

  .cta-btn { flex-shrink: 0; }

  @media (max-width: 720px) {
    .cta-inner { flex-direction: column; align-items: flex-start; }
    .cta-btn { width: 100%; }
  }
</style>
