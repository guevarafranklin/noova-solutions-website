---
const navLinks = [
  { href: "/services", label: "Services" },
  { href: "/comerciafy", label: "AI Agents" },
  { href: "/about", label: "Work" },
  { href: "/contact", label: "Contact" },
];
---

<header class="navbar">
  <div class="container navbar-inner">
    <a href="/" class="navbar-brand" aria-label="Noova Solutions — Home">
      <img
        src="/brand/nova-spark-horizontal.svg"
        alt="Noova Solutions"
        width="220"
        height="48"
        class="navbar-logo"
      />
    </a>

    <nav class="navbar-nav" aria-label="Primary">
      <ul class="navbar-links">
        {navLinks.map((link) => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
      </ul>
    </nav>

    <a href="/contact" class="btn btn-primary navbar-cta">Let's Talk</a>

    <button
      class="navbar-toggle"
      type="button"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
      data-nav-toggle
    >
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>

  <div id="mobile-menu" class="navbar-mobile" hidden>
    <ul>
      {navLinks.map((link) => (
        <li><a href={link.href}>{link.label}</a></li>
      ))}
      <li><a href="/contact" class="btn btn-primary">Let's Talk</a></li>
    </ul>
  </div>
</header>

<script>
  const toggle = document.querySelector("[data-nav-toggle]");
  const menu = document.getElementById("mobile-menu");
  toggle?.addEventListener("click", () => {
    const expanded = toggle.getAttribute("aria-expanded") === "true";
    toggle.setAttribute("aria-expanded", String(!expanded));
    toggle.setAttribute("aria-label", expanded ? "Open menu" : "Close menu");
    if (menu) {
      if (expanded) menu.setAttribute("hidden", "");
      else menu.removeAttribute("hidden");
    }
  });
</script>

<style>
  .navbar {
    position: sticky;
    top: 0;
    z-index: 50;
    background-color: rgba(251, 247, 242, 0.88);
    backdrop-filter: saturate(180%) blur(12px);
    -webkit-backdrop-filter: saturate(180%) blur(12px);
    border-bottom: 1px solid var(--color-line);
  }

  .navbar-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-6);
    padding-block: var(--space-4);
  }

  .navbar-brand {
    display: inline-flex;
    align-items: center;
  }

  .navbar-brand:hover { color: inherit; }

  .navbar-logo {
    height: 48px;
    width: auto;
    display: block;
  }

  .navbar-nav { flex: 1; display: flex; justify-content: center; }

  .navbar-links {
    display: flex;
    gap: var(--space-8);
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .navbar-links a {
    color: var(--color-ink);
    font-size: var(--fs-body);
    font-weight: 400;
    padding-block: var(--space-2);
    transition: color var(--transition-fast);
  }

  .navbar-links a:hover { color: var(--color-primary); }

  .navbar-cta { flex-shrink: 0; }

  .navbar-toggle {
    display: none;
    background: none;
    border: none;
    padding: var(--space-2);
    flex-direction: column;
    gap: 5px;
  }

  .navbar-toggle span {
    display: block;
    width: 22px;
    height: 2px;
    background-color: var(--color-ink);
    border-radius: 2px;
  }

  .navbar-mobile {
    border-top: 1px solid var(--color-line);
    background-color: var(--color-paper);
    padding: var(--space-4) var(--section-px) var(--space-6);
  }

  .navbar-mobile ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .navbar-mobile a {
    display: block;
    padding: var(--space-3) 0;
    color: var(--color-ink);
    font-weight: 400;
  }

  .navbar-mobile a.btn {
    margin-top: var(--space-3);
    display: inline-flex;
    color: var(--color-on-brand);
  }

  @media (max-width: 860px) {
    .navbar-nav, .navbar-cta { display: none; }
    .navbar-toggle { display: flex; }
  }
</style>
