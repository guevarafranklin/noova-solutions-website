---
interface Props {
  eyebrow?: string;
  headline: string;
  subheadline: string;
  primaryCta?: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
}

const { eyebrow, headline, subheadline, primaryCta, secondaryCta } = Astro.props;
---

<section class="hero">
  <div class="container hero-inner">
    <div class="hero-copy">
      {eyebrow && <span class="eyebrow">{eyebrow}</span>}
      <h1 class="t-display">{headline}</h1>
      <p class="hero-sub">{subheadline}</p>

      {(primaryCta || secondaryCta) && (
        <div class="hero-ctas">
          {primaryCta && (
            <a href={primaryCta.href} class="btn btn-primary btn-lg">{primaryCta.label}</a>
          )}
          {secondaryCta && (
            <a href={secondaryCta.href} class="btn btn-secondary btn-lg">{secondaryCta.label}</a>
          )}
        </div>
      )}
    </div>

    <aside class="hero-mark" aria-hidden="true">
      <img src="/brand/nova-spark-primary.svg" alt="" width="440" height="440" />
    </aside>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    background-color: var(--color-paper);
    padding-block: var(--space-22);
    border-bottom: 1px solid var(--color-line);
  }

  .hero-inner {
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(0, 1fr);
    align-items: center;
    gap: var(--space-12);
  }

  .hero-copy h1 { margin-bottom: var(--space-6); color: var(--color-ink); }

  .hero-sub {
    font-size: var(--fs-body-lg);
    color: var(--color-muted);
    max-width: 52ch;
    margin: 0 0 var(--space-10);
    line-height: 1.6;
  }

  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .hero-mark {
    display: grid;
    place-items: center;
  }

  .hero-mark img {
    width: 100%;
    max-width: 380px;
    height: auto;
  }

  @media (max-width: 860px) {
    .hero-inner { grid-template-columns: 1fr; }
    .hero-mark { order: -1; justify-self: flex-start; }
    .hero-mark img { max-width: 200px; }
  }

  @media (max-width: 560px) {
    .hero-ctas { flex-direction: column; align-items: stretch; }
    .hero-ctas .btn { width: 100%; }
  }
</style>
